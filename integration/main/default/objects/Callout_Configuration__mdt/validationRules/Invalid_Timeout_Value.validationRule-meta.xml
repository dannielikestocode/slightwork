<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Invalid_Timeout_Value</fullName>
    <active>true</active>
    <description>Enforces a valid request timeout value.</description>
    <errorConditionFormula>OR(Timeout__c &gt; 120000, Timeout__c &lt; 1)</errorConditionFormula>
    <errorDisplayField>Timeout__c</errorDisplayField>
    <errorMessage>Timeout must be a value from 1 - 120000 (inclusive)</errorMessage>
</ValidationRule>
